FROM maven:3.9.12-eclipse-temurin-21 AS builder
WORKDIR /app
COPY . .
RUN mvn -pl backend/yuntan-monolith-app -am clean package -DskipTests

FROM eclipse-temurin:21-jre
WORKDIR /app
COPY --from=builder /app/backend/yuntan-monolith-app/target/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-Xms256m", "-Xmx512m", "-jar", "app.jar"]